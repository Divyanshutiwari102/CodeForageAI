{
  "info": {
    "name": "CodeForage AI API",
    "description": "Complete API collection for CodeForage AI — AI SaaS Backend.\n\n**Setup:**\n1. Import this collection\n2. Create an environment with variables: `baseUrl` (e.g. `http://localhost:8080`) and `token` (leave empty)\n3. Call POST /api/auth/login — token is stored automatically\n4. All subsequent requests use the stored token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api", "auth", "signup"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('token', res.accessToken);",
                  "  pm.environment.set('token', res.accessToken);",
                  "  console.log('Token saved:', res.accessToken.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"]}
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List My Projects",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/projects", "host": ["{{baseUrl}}"], "path": ["api", "projects"]}
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/projects/1", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1"]}
          }
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/projects", "host": ["{{baseUrl}}"], "path": ["api", "projects"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My React App\",\n  \"isPublic\": false\n}"
            }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/projects/1", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Updated App\",\n  \"isPublic\": true\n}"
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{baseUrl}}/api/projects/1", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1"]}
          }
        },
        {
          "name": "List Members",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/projects/1/members", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "members"]}
          }
        },
        {
          "name": "Invite Member",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/projects/1/members", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "members"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"collaborator@example.com\",\n  \"role\": \"EDITOR\"\n}"
            }
          }
        },
        {
          "name": "Update Member Role",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/projects/1/members/2", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "members", "2"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"VIEWER\"\n}"
            }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{baseUrl}}/api/projects/1/members/2", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "members", "2"]}
          }
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "Get File Tree",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/projects/1/files", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "files"]}
          }
        },
        {
          "name": "Get File Content",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/projects/1/files/src/App.tsx", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "files", "src", "App.tsx"]}
          }
        },
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/api/projects/1/files?path=src/App.tsx", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "files"], "query": [{"key": "path", "value": "src/App.tsx"}]},
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": ""}
              ]
            }
          }
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{baseUrl}}/api/projects/1/files/src/App.tsx", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "files", "src", "App.tsx"]}
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "List Chat Sessions",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/projects/1/chat-sessions", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "chat-sessions"]}
          }
        },
        {
          "name": "Create Chat Session",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/projects/1/chat-sessions", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "chat-sessions"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Chat\"\n}"
            }
          }
        },
        {
          "name": "Get Session Messages",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/chat/sessions/1/messages", "host": ["{{baseUrl}}"], "path": ["api", "chat", "sessions", "1", "messages"]}
          }
        },
        {
          "name": "Stream Chat (SSE)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "text/event-stream"}
            ],
            "url": {"raw": "{{baseUrl}}/api/chat/stream", "host": ["{{baseUrl}}"], "path": ["api", "chat", "stream"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": 1,\n  \"projectId\": 1,\n  \"prompt\": \"Add a button component\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Preview",
      "item": [
        {
          "name": "Start Preview",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/api/projects/1/previews", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "previews"]}
          }
        },
        {
          "name": "List Previews",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/projects/1/previews", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "previews"]}
          }
        },
        {
          "name": "Get Preview Status",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/projects/1/previews/1", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "previews", "1"]}
          }
        },
        {
          "name": "Stop Preview",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{baseUrl}}/api/projects/1/previews/1", "host": ["{{baseUrl}}"], "path": ["api", "projects", "1", "previews", "1"]}
          }
        }
      ]
    },
    {
      "name": "Billing",
      "item": [
        {
          "name": "List Plans",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/plans", "host": ["{{baseUrl}}"], "path": ["api", "plans"]}
          }
        },
        {
          "name": "Get My Subscription",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/me/subscription", "host": ["{{baseUrl}}"], "path": ["api", "me", "subscription"]}
          }
        },
        {
          "name": "Create Checkout Session",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/stripe/checkout", "host": ["{{baseUrl}}"], "path": ["api", "stripe", "checkout"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priceId\": \"price_xxxx\"\n}"
            }
          }
        },
        {
          "name": "Create Portal Session",
          "request": {
            "method": "POST",
            "url": {"raw": "{{baseUrl}}/api/stripe/portal", "host": ["{{baseUrl}}"], "path": ["api", "stripe", "portal"]}
          }
        }
      ]
    },
    {
      "name": "Usage",
      "item": [
        {
          "name": "Get Today's Usage",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/usage/today", "host": ["{{baseUrl}}"], "path": ["api", "usage", "today"]}
          }
        },
        {
          "name": "Get Usage Limits",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/usage/limits", "host": ["{{baseUrl}}"], "path": ["api", "usage", "limits"]}
          }
        }
      ]
    }
  ]
}
