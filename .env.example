# =========================
# CodeForageAI environment
# =========================
#
# Canonical runtime structure:
# - backend: /CodeForageAI-main
# - frontend: /CodeForageAI-main/frontend
#
# This file documents required backend and frontend env values for production.

# -------- Backend (CodeForageAI-main) --------
DB_URL=jdbc:postgresql://localhost:5432/codeforagedb
DB_USER=postgres
DB_PASSWORD=change-me

JWT_SECRET=replace-with-at-least-32-characters
JWT_ACCESS_TOKEN_TTL_MS=3600000

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=codeforageai

REDIS_HOST=localhost
REDIS_PORT=6379

OPENAI_API_KEY=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYMENT_PRO_AMOUNT_PAISE=99900

# Comma-separated frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cookie auth hardening
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=None

# Optional observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOKI_ENDPOINT=http://localhost:3100

# -------- Frontend (CodeForageAI-main/frontend) --------
NEXT_PUBLIC_API_URL=http://localhost:8080/api
